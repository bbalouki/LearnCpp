  "version": "0.2.0",
  "configurations": [
    {
      "name": "CodeLLDB: CMake Target (All Compilers)",
      "type": "lldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "console": "integratedTerminal"
    },

    {
      "name": "mingw-debug-lunch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/LearnCpp.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "GCC/Clang-MingW-Debug-Build"
    },

    {
      "name": "mingw-release-lunch",
