{
  "tasks": [
    {
      "label": "GCC/Clang MingW Debug Preset",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "mingw"],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },

    {
      "label": "GCC/Clang MingW Release Preset",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "mingw-rel"],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },

    {
      "label": "GCC/Clang-MingW-Debug-Build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "dependsOn": "GCC/Clang MingW Debug Preset"
    },
    {
      "label": "GCC/Clang-MingW-Release-Build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "dependsOn": "GCC/Clang MingW Release Preset"
    },


    {
      "label": "MSVC Configure Preset",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "win"],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "detail": "Run CMake configuration"
    },

    {
      "label": "MSVC-Debug-Build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${workspaceFolder}/build", "--config", "Debug"],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "dependsOn": "MSVC Configure Preset"
    },
    {
      "label": "MSVC-Release-Build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${workspaceFolder}/build", "--config", "Release"],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "dependsOn": "MSVC Configure Preset"
    }
  ],
  "version": "2.0.0"
}
