{
  "version": 3,
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "LEARNCPP_BUILD_BENCHMARKS": "ON",
        "LEARNCPP_BUILD_EXAMPLES": "ON",
        "LEARNCPP_BUILD_TESTS": "ON",
        "LEARNCPP_PROJECT_ENV": "DEV",
        "LEARNCPP_APPLY_CLANG_TIDY_GLOBALY": "ON",
        "LEARNCPP_APPLY_FORMATING": "ON"
      }
    },
    {
      "name": "_vcpkg",
      "hidden": true,
      "inherits": ["_base"],
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "_conan",
      "hidden": true,
      "inherits": ["_base"],
      "toolchainFile": "${sourceDir}/build/conan_toolchain.cmake"
    },
    {
      "name": "_debug",
      "hidden": true,
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "_release",
      "hidden": true,
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "_coverage",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LEARNCPP_ADD_COVERAGE_ANALYSIS": "ON"
      }
    },
    {
      "name": "_sanitize",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LEARNCPP_ENABLE_ADDRESS_SANITIZER": "ON"
      }
    },
    {
      "name": "_VS",
      "hidden": true,
      "generator": "Visual Studio 17 2022"
    },
    {
      "name": "_ninja",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "_mingw",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_HOST_TRIPLET": "x64-mingw-static"
      }
    },

    {
      "name": "win",
      "inherits": ["_VS", "_vcpkg"],
      "displayName": "MSVC + vcpkg",
      "description": "Build using VS 2022 using vcpkg for dependency management."
    },
    {
      "name": "win-conan",
      "inherits": ["_VS", "_conan"],
      "displayName": "MSVC + Conan",
      "description": "Build using VS 2022 using Conan as the dependency manager."
    },

    {
      "name": "win-san",
      "inherits": ["_VS", "_vcpkg", "_sanitize"],
      "displayName": "MSVC + vcpkg Sanitizers",
      "description": "Debug build with VS 200 enabling sanitizers using vcpkg as pkg manager."
    },
    {
      "name": "cross",
      "inherits": ["_ninja", "_vcpkg", "_debug", "_mingw"],
      "displayName": "(GCC/Clang) + vcpkg Cross-Platform Debug",
      "description": "Build with Ninja in Debug mode using vcpkg as pkg manager."
    },
    {
      "name": "cross-rel",
      "inherits": ["_ninja", "_vcpkg", "_release", "_mingw"],
      "displayName": "(GCC/Clang) + vcpkg Cross-Platform Release",
      "description": "Optimized Release build with Ninja using vcpkg as pkg manager."
    },
    {
      "name": "cross-conan",
      "inherits": ["_ninja", "_conan", "_debug"],
      "displayName": "(GCC/Clang) + Conan Cross-Platform Debug",
      "description": "Build with Ninja in Debug mode using Conan as pkg manager."
    },
    {
      "name": "cross-conan-rel",
      "inherits": ["_ninja", "_conan", "_release"],
      "displayName": "(GCC/Clang) + Conan Cross-Platform Release",
      "description": "Optimized Release build with Ninja using Conan as pkg manager."
    },
    {
      "name": "cross-cov",
      "inherits": ["_ninja", "_vcpkg", "_coverage", "_mingw"],
      "displayName": "(GCC/Clang) + vcpkg Cross-Platform Coverage",
      "description": "Instrumented with Ninja for code coverage analysis, using vcpkg as pkg manager."
    },
    {
      "name": "cross-san",
      "inherits": ["_ninja", "_vcpkg", "_sanitize", "_mingw"],
      "displayName": "(GCC/Clang) + vcpkg Cross-Platform Sanitizers",
      "description": "Debug build with Ninja enabling sanitizers using vcpkg as pkg manager."
    }
  ]
}
